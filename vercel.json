{
  "crons": [
    {
      "path": "/api/cron/run?job=blog",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/run?job=blog",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/run?job=blog",
      "schedule": "7 0 * * *"
    },
    {
      "path": "/api/cron/run?job=blog",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/run?job=blog",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/run?job=blog",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/run?job=ships",
      "schedule": "0 3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/favicon-(:filename)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/android-icon-(:filename)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/apple-icon-(:filename)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/apple-icon.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/apple-touch-icon.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/ms-icon-(:filename)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/site.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=1800, s-maxage=86400, stale-while-revalidate=604800"
        },
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        }
      ]
    }
  ]
}
